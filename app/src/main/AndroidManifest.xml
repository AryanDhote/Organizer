<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.my.organizer">

    <!-- Required permissions, add others if needed -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MyOrganizerApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.MyOrganizer">

        <!-- Main Activity -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Expense List Fragment Activity -->
        <activity
            android:name=".activities.ExpenseListActivity"
            android:label="Expenses" />

        <!-- Add/Edit Expense Activity -->
        <activity
            android:name=".activities.AddEditExpenseActivity"
            android:label="Add/Edit Expense" />

        <!-- To-Do List Fragment Activity -->
        <activity
            android:name=".activities.ToDoListActivity"
            android:label="To-Do List" />

        <!-- Other Activities (if any) -->
        <!-- Add them here -->

    </application>

</manifest>
