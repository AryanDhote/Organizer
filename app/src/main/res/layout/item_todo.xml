<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="8dp"
    android:padding="16dp"
    tools:context=".activities.ToDoListActivity">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp">

        <!-- ToDo Title -->
        <TextView
            android:id="@+id/tv_todo_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ToDo Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"/>

        <!-- ToDo Description -->
        <TextView
            android:id="@+id/tv_todo_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description of the ToDo"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"/>

        <!-- ToDo Due Date -->
        <TextView
            android:id="@+id/tv_todo_due_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due Date: 01/01/2025"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"/>

        <!-- ToDo Expiry Time -->
        <TextView
            android:id="@+id/tv_todo_expiry_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expiry Time: 12:00 PM"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
