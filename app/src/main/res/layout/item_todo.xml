<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtToDoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To-Do Title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtToDoDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To-Do Description"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ✅ Fixed ImageButton with correct size and constraints -->
    <ImageButton
        android:id="@+id/buttonDeleteToDo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_delete"
        android:contentDescription="@string/delete_to_do"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="center"
        android:padding="12dp"/>
</LinearLayout>
