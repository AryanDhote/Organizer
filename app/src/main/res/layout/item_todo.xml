<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="6dp" android:elevation="4dp" android:padding="10dp">

    <LinearLayout android:orientation="vertical" android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView android:id="@+id/tv_todo_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Title" android:textStyle="bold" android:textSize="16sp"/>

        <TextView android:id="@+id/tv_todo_description"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Description" android:textSize="14sp" android:textColor="@android:color/darker_gray"/>

        <TextView android:id="@+id/tv_todo_due_date"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="01 Jan 2025" android:textSize="12sp" android:textColor="@android:color/darker_gray"/>

        <TextView android:id="@+id/tv_todo_expiry_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="12:00 PM" android:textSize="12sp" android:textColor="@android:color/darker_gray"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
