<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- OPTIONAL PRIORITY CHIP -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_priority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="High"
            app:chipCornerRadius="8dp"
            app:chipBackgroundColor="@color/red"
            android:textColor="@android:color/white"
            android:visibility="gone"
            android:layout_alignParentStart="true" />

        <!-- TITLE -->
        <TextView
            android:id="@+id/tv_todo_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buy Groceries"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_toEndOf="@id/chip_priority"
            android:layout_marginStart="8dp"
            android:layout_alignParentTop="true" />

        <!-- DUE DATE -->
        <TextView
            android:id="@+id/tv_todo_due_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01 Jan 2026"
            android:textAppearance="?attr/textAppearanceCaption"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/tv_todo_title" />

        <!-- DESCRIPTION -->
        <TextView
            android:id="@+id/tv_todo_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_todo_title"
            android:layout_marginTop="6dp"
            android:text="Summary of the task goes here... up to 3 lines."
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- EXPIRY TIME -->
        <TextView
            android:id="@+id/tv_todo_expiry_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:00 AM"
            android:layout_below="@id/tv_todo_description"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceCaption" />

        <!-- MULTI-SELECT OVERLAY -->
        <FrameLayout
            android:id="@+id/selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/selection_overlay"
                android:alpha="0.35" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                android:layout_gravity="end|top">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:layout_gravity="center"
                    app:tint="@android:color/white" />
            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
